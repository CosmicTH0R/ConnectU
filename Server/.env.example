# ════════════════════════════════════════════════════════════════
#  LOCAL DEVELOPMENT  (docker-compose up -d)
# ════════════════════════════════════════════════════════════════
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_at_least_64_chars
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=instagram
POSTGRES_PASSWORD=instagram_password
POSTGRES_DB=instagram
DATABASE_URL=postgresql://instagram:instagram_password@localhost:5432/instagram

# ─── MongoDB ─────────────────────────────────────────────────
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=instagram
MONGO_PASSWORD=instagram_password
MONGO_DB=instagram
MONGO_URI=mongodb://instagram:instagram_password@localhost:27017/instagram

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_URL=redis://:redis_password@localhost:6379

# ─── Kafka ───────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=instagram-backend
KAFKA_GROUP_ID_PREFIX=instagram

# ─── Elasticsearch ── NOT USED (replaced by PostgreSQL FTS) ──
# No Elasticsearch needed — search uses pg tsvector/GIN indexes

# ─── Media Storage ──────────────────────────────────────────
# LOCAL: MinIO (Docker)
MEDIA_PROVIDER=minio
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minio_access_key
MINIO_SECRET_KEY=minio_secret_key
MINIO_BUCKET_POSTS=posts
MINIO_BUCKET_STORIES=stories
MINIO_BUCKET_PROFILES=profiles
MINIO_BUCKET_CHAT=chat

# PRODUCTION: Cloudinary (free 25GB) — https://cloudinary.com
# MEDIA_PROVIDER=cloudinary
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# ─── Kafka SASL (Upstash Kafka in production) ─────────────────
# LOCAL: no SASL needed
KAFKA_USE_SASL=false
# PRODUCTION (Upstash): uncomment below
# KAFKA_USE_SASL=true
# KAFKA_SASL_USERNAME=your-upstash-username
# KAFKA_SASL_PASSWORD=your-upstash-password

# ─── Service Ports ───────────────────────────────────────────
API_GATEWAY_PORT=3000
GRAPHQL_GATEWAY_PORT=4000
USER_SERVICE_PORT=3001
POST_SERVICE_PORT=3002
FEED_SERVICE_PORT=3003
STORY_SERVICE_PORT=3004
CHAT_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006
MEDIA_SERVICE_PORT=3007
SEARCH_SERVICE_PORT=3008
RECOMMENDATION_SERVICE_PORT=3009
FEATURE_FLAG_SERVICE_PORT=3010
AB_TESTING_SERVICE_PORT=3011

# ─── Service URLs (internal) ─────────────────────────────────
USER_SERVICE_URL=http://localhost:3001
POST_SERVICE_URL=http://localhost:3002
FEED_SERVICE_URL=http://localhost:3003
STORY_SERVICE_URL=http://localhost:3004
CHAT_SERVICE_URL=http://localhost:3005
NOTIFICATION_SERVICE_URL=http://localhost:3006
MEDIA_SERVICE_URL=http://localhost:3007
SEARCH_SERVICE_URL=http://localhost:3008
RECOMMENDATION_SERVICE_URL=http://localhost:3009
FEATURE_FLAG_SERVICE_URL=http://localhost:3010
AB_TESTING_SERVICE_URL=http://localhost:3011

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:4000


# ════════════════════════════════════════════════════════════════
#  PRODUCTION  (Render.com — 100% free tier)
#  1. Create accounts on the free services below
#  2. Set these as Environment Variables in Render dashboard
# ════════════════════════════════════════════════════════════════

# NODE_ENV=production

# ─── PostgreSQL → Neon (free) ────────────────────────────────────
# https://neon.tech  |  free: 0.5GB, serverless, no credit card
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/instagram?sslmode=require

# ─── MongoDB → MongoDB Atlas M0 (free) ───────────────────────────
# https://mongodb.com/atlas  |  free: 512MB, shared cluster
# MONGO_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/instagram?retryWrites=true&w=majority

# ─── Redis → Upstash Redis (free) ────────────────────────────────
# https://upstash.com  |  free: 10,000 commands/day, 256MB
# REDIS_URL=rediss://default:token@global-xxxx.upstash.io:6379

# ─── Kafka → Upstash Kafka (free) ────────────────────────────────
# https://upstash.com/kafka  |  free: 10,000 messages/day
# KAFKA_BROKERS=full-corgi-xxxx-us1-kafka.upstash.io:9092
# KAFKA_USE_SASL=true
# KAFKA_SASL_USERNAME=your-upstash-username
# KAFKA_SASL_PASSWORD=your-upstash-password

# ─── Media → Cloudinary (free) ───────────────────────────────────
# https://cloudinary.com  |  free: 25GB storage + 25GB bandwidth/month
# MEDIA_PROVIDER=cloudinary
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# ─── Service URLs on Render (fill after deploying each service) ──
# USER_SERVICE_URL=https://instagram-user-svc.onrender.com
# POST_SERVICE_URL=https://instagram-post-svc.onrender.com
# FEED_SERVICE_URL=https://instagram-feed-svc.onrender.com
# STORY_SERVICE_URL=https://instagram-story-svc.onrender.com
# CHAT_SERVICE_URL=https://instagram-chat-svc.onrender.com
# NOTIFICATION_SERVICE_URL=https://instagram-notification-svc.onrender.com
# MEDIA_SERVICE_URL=https://instagram-media-svc.onrender.com
# SEARCH_SERVICE_URL=https://instagram-search-svc.onrender.com
# RECOMMENDATION_SERVICE_URL=https://instagram-recommendation-svc.onrender.com
# FEATURE_FLAG_SERVICE_URL=https://instagram-feature-flag-svc.onrender.com
# AB_TESTING_SERVICE_URL=https://instagram-ab-testing-svc.onrender.com

# ─── CORS (production) ───────────────────────────────────────────
# CORS_ORIGINS=https://your-frontend.onrender.com
